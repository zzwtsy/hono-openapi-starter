NODE_ENV=development
PORT=3001

# 日志：fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
# 保留的最大日志文件数量
LOG_MAX_FILES=90

# 数据库
DATABASE_URL=postgres://user:password@localhost:5432/app

# Better Auth
# 认证密钥，长度至少 32 位，生产环境务必更换
BETTER_AUTH_SECRET=please-change-me-with-at-least-32-chars
# 认证服务公网访问地址
BETTER_AUTH_URL=http://localhost:3001
# 可信任的来源列表，逗号分隔
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173
# 禁止注册
DISABLE_SIGN_UP=true

# API 与文档
# 允许的前端来源，逗号分隔；留空则放行所有来源
CORS_ORIGINS=http://localhost:5173
# 生产环境是否公开 /openapi.json（默认关闭）
OPENAPI_PUBLIC=false

# bootstrap（首次部署造第一个 admin，用后可清除密码；dev 用 db:seed 即可）
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-at-least-8
BOOTSTRAP_ROOT_ORG_ID=org-root
