{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config src/core/auth/better-auth.ts --output src/db/schema/auth-schema.ts -y"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/zod-openapi": "catalog:",
    "@loglayer/hono": "catalog:",
    "@loglayer/plugin-redaction": "catalog:",
    "@loglayer/transport-log-file-rotation": "catalog:",
    "@loglayer/transport-simple-pretty-terminal": "catalog:",
    "@scalar/hono-api-reference": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "loglayer": "catalog:",
    "postgres": "catalog:",
    "serialize-error": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "tsc-alias": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
